{
	"version": 3,
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"title": "Comic",
	"slug": "post-terms-2",
	"blockTypes": [
		"core/post-terms"
	],
	"styles": {
		"color": {
			"background": "var:preset|color|accent-3"
		},
		"spacing": {
			"padding": {
				"right": "var:preset|spacing|20",
				"left": "var:preset|spacing|20"
			}
		},
		"elements": {
			"link": {
				"typography": {
					"fontFamily": "var:preset|font-family|bangers",
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "400",
					"textDecoration": "none",
					"letterSpacing": "8%"
				},
				"css": "transition: font-size 0.05s ease-out; will-change: font-size;",
				":hover": {
					"typography": {
						"fontSize": "var:preset|font-size|large",
						"textDecoration": "underline"
					}
				}
			}
		}
	}
}